{
  // https://github.com/mxkrsv/dotfiles-old/tree/42e615c5e0f09e3d4dfef63363cec134ea6410a9/.config/waybar
	"layer": "top",
	"position": "top",

	"modules-left": [
    "ext/workspaces",
		"custom/arrow10"
	],

	"modules-right": [
		"custom/keyboard",
		"custom/arrow6",
		"cpu",
		"memory",
    "custom/disk",
		"custom/arrow5",
		"battery",
		"custom/arrow4",
		"network",
		"custom/arrow3",
		"pulseaudio",
		"custom/arrow2",
		"clock#date",
		"custom/arrow1",
		"clock#time"
	],

	"modules-center": [
		"tray"
	],

	// Modules

	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {time}",
		"format-charging": "{icon} {capacity}%",
		"format-charging-full": "{icon} {capacity}%",
		"format-full": "{icon}",
		"format-alt": " {power:.2}W",
		"format-icons": [
			"󰂎",
			"󰁺",
			"󰁻",
			"󰁼",
			"󰁽",
			"󰁿",
			"󰂀",
			"󰂁",
			"󰂂",
			"󰁹"
		],
		"tooltip": true,
		"events": {
			"on-discharging-warning": "notify-send -u normal 'Low Battery'",
			"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
			"on-charging-100": "notify-send -u normal 'Battery Full!'"
		}
	},

	"clock#time": {
		"interval": 10,
		"format": " {:%H:%M}",
		"tooltip": false
	},

	"clock#date": {
		"interval": 20,
		"format": "󰃶 {:%e}",
		"tooltip": true,
		"tooltip-format": "{:%e %B %Y}"
	},

	"custom/keyboard": {
    "interval": 5,
		"format": " {text}",
    "exec": "~/.config/waybar/scripts/current_kb_layout.sh",
		"tooltip": false,
    "tooltip-format": "{text}"
	},

	"cpu": {
		"interval": 5,
		"tooltip": true,
		"format": "{icon}",
    "tooltip-format": "  {usage}%",
		"states": {
			"warning": 70,
			"critical": 90
		},
    "format-icons": ["󰄰 ", "󰪞 ", "󰪟 ", "󰪠 ", "󰪡 ", "󰪢 ", "󰪣 ", "󰪤 ", "󰪥 " ]
	},

	"memory": {
		"interval": 5,
    "format": "{icon}",
		"tooltip-format": "  {used:0.1f}G/{total:0.1f}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": true,
    "format-icons": ["󰄰 ", "󰪞 ", "󰪟 ", "󰪠 ", "󰪡 ", "󰪢 ", "󰪣 ", "󰪤 ", "󰪥 " ]
	},

	"custom/disk": {
    "interval": 30,
		"format": "{icon}",
    "exec": "~/.config/waybar/scripts/disk_usage.sh",
		"tooltip": true,
    "tooltip-format": "{text}",
		"states": {
			"warning": 70,
			"critical": 80
		},
    "return-type": "json",
    "format-icons": ["󰄰 ", "󰪞 ", "󰪟 ", "󰪠 ", "󰪡 ", "󰪢 ", "󰪣 ", "󰪤 ", "󰪥 " ]
	},

	"network": {
		"interval": 5,
		"format-wifi": "{icon}",
		"format-ethernet": "  {ifname}",
		"format-disconnected": "󰤮 ",
		"format-alt": "  {ipaddr}/{cidr}",
		"tooltip": true,
		"tooltip-format": "{ifname}",
		"tooltip-format-wifi": "{essid} ({signalStrength}%)",
		"tooltip-format-ethernet": "Wired Connection",
		"tooltip-format-disconnected": "Disconnected",
	        "format-icons": ["󰤫 ", "󰤟 ", "󰤢 ", "󰤥 ", "󰤨 "]
	},

  "ext/workspaces": {
    "format": "{icon}",
    "ignore-hidden": true,
    "on-click": "activate",
    "on-click-right": "deactivate",
    "sort-by-id": true
  },

	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "{icon} {volume}%",
		"format-muted": "",
		"format-icons": {
			"headphone": " ",
			"hands-free": " ",
			"headset": " ",
			"phone": " ",
			"portable": " ",
			"car": " ",
			"default": [" ", " "]
		},
		"scroll-step": 1,
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"tooltip": false
	},

	"temperature": {
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}°",
		"format-icons": [
			"",
			"",
			"",
			"",
			""
		],
		"tooltip": false
	},

	"tray": {
		"icon-size": 18
		//"spacing": 10
	},

	"custom/arrow0": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow1": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow2": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow3": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow4": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow5": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow6": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow7": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow8": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow9": {
		"format": "",
		"tooltip": false
	},

	"custom/arrow10": {
		"format": "",
		"tooltip": false
	}
}

